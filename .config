# ==================== 目标系统 (x86_64) ====================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_Generic=y

# ==================== 固件大小 ====================
CONFIG_TARGET_ROOTFS_PARTSIZE=1536   # 1.5GB，足够未来扩展

# ==================== IPv6 完整支持 ====================
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_kmod-ipv6=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_luci-proto-ipv6=y

# ==================== LuCI Web 界面 ====================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-openssl=y
CONFIG_BUILD_NLS=y
CONFIG_PACKAGE_luci-compat=y

# ==================== 中文支持 ====================
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# ==================== 核心插件 ====================
# iStore 应用商店
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-lib-ipkg=y

# OpenClash
CONFIG_PACKAGE_luci-app-openclash=y

# mwan3 (双WAN负载均衡)
CONFIG_PACKAGE_mwan3=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=y

# 其他实用插件
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y

# ==================== RTL8125 网卡驱动 ====================
# 内核自带驱动 (r8169 兼容 RTL8125，基本可用)
CONFIG_PACKAGE_kmod-r8169=y
# Realtek 官方闭源驱动 (性能更好，但可能不在默认源中，若编译失败可移除)
CONFIG_PACKAGE_kmod-r8125=y

# ==================== 虚拟化与 VirtIO 驱动 (PVE 优化) ====================
CONFIG_PACKAGE_kmod-virtio=y
CONFIG_PACKAGE_kmod-virtio-net=y
CONFIG_PACKAGE_kmod-virtio-balloon=y
CONFIG_PACKAGE_kmod-virtio-blk=y

# ==================== 基础网络工具 ====================
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_iperf3=y

# ==================== 其他推荐 (可选) ====================
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_luci-app-diskman=y

# 添加主题
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-i18n-argon-zh-cn=y
CONFIG_PACKAGE_luci-theme-design=y
CONFIG_PACKAGE_luci-i18n-design-zh-cn=y
